.print-btn {
    background: #1A1B41;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    margin-right: 10px;
}

.print-btn:hover {
    background: #23254a;
}

#print-preview-wrapper {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
}

@media print {
    @page {
        size: A4 portrait;
        margin: 15mm;
    }
    
    * {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    body * {
        visibility: hidden;
    }
    
    #print-preview-wrapper,
    #print-preview-wrapper * {
        visibility: visible !important;
    }
    
    #print-preview-wrapper {
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        width: 100% !important;
        height: auto !important;
        display: block !important;
        font-family: 'Times New Roman', serif;
        font-size: 12px;
        line-height: 1.4;
        color: #000 !important;
        background: white !important;
        padding: 0 !important;
        margin: 0 !important;
    }
    
    .pnp-header {
        text-align: center;
        border: 2px solid #000;
        padding: 15px;
        margin-bottom: 20px;
    }
    
    .pnp-footer {
        border-top: 2px solid #000;
        padding: 15px;
        margin-top: 30px;
        background: white;
    }
    
    .case-content {
        margin: 20px 0;
    }
    
    .info-grid {
        display: grid !important;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin: 15px 0;
    }
    
    .info-item {
        border: 1px solid #000 !important;
        padding: 8px;
        background: white !important;
    }
    
    .section-title {
        font-size: 14px;
        font-weight: bold;
        margin: 15px 0 8px 0;
        border-bottom: 1px solid #000;
        padding-bottom: 3px;
    }
    
    .pnp-logo-section {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 10px;
    }
    
    .pnp-seal {
        width: 60px;
        height: 60px;
        border: 2px solid #000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
    }
    
    .pnp-title h1, .pnp-title h2, .pnp-title h3 {
        margin: 2px 0;
        font-weight: bold;
        color: #000 !important;
    }
    
    .pnp-title h1 { font-size: 16px; }
    .pnp-title h2 { font-size: 14px; }
    .pnp-title h3 { font-size: 12px; text-decoration: underline; }
    
    .report-info {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        font-weight: bold;
        border-top: 1px solid #000;
        padding-top: 5px;
        margin-top: 10px;
    }
    
    .signature-section {
        display: flex;
        justify-content: space-around;
        margin-bottom: 15px;
    }
    
    .signature-line {
        text-align: center;
    }
    
    .signature-box {
        width: 150px;
        height: 30px;
        border-bottom: 1px solid #000;
        margin-bottom: 5px;
    }
    
    .signature-label {
        font-size: 10px;
        font-weight: bold;
        color: #000 !important;
    }
    
    .footer-note {
        text-align: center;
        font-size: 8px;
        font-style: italic;
    }
    
    .footer-note p {
        margin: 2px 0;
        color: #000 !important;
    }
    
    .info-item h1 {
        font-size: 10px;
        font-weight: bold;
        margin: 0 0 3px 0;
        text-transform: uppercase;
        color: #000 !important;
    }
    
    .info-item p {
        font-size: 11px;
        margin: 0;
        color: #000 !important;
    }
    
    .full-width {
        grid-column: 1 / -1;
    }
    
    .print-images {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 15px 0;
        justify-content: center;
    }
    
    .print-image {
        max-width: 120px !important;
        max-height: 150px !important;
        border: 1px solid #000 !important;
        object-fit: cover;
    }
}
